---
import PageLayout from "@/layouts/PageLayout.astro";
import { t, type Lang, getLocalizedPath } from "@/i18n/utils";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "ar" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };

const allPosts = await getCollection("blog", (post) => post.data.locale === lang);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [
  { key: "all", label: t(lang, "blog.categories.all") },
  { key: "tips", label: t(lang, "blog.categories.tips") },
  { key: "tax", label: t(lang, "blog.categories.tax") },
  { key: "updates", label: t(lang, "blog.categories.updates") },
];

const categoryBadgeColors: Record<string, string> = {
  tips: "bg-amber-50 text-amber-700 border-amber-200",
  tax: "bg-green-50 text-green-700 border-green-200",
  updates: "bg-blue-50 text-blue-700 border-blue-200",
};

function formatDate(date: Date, locale: string): string {
  return date.toLocaleDateString(locale === "ar" ? "ar-SA" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<PageLayout
  title={`${t(lang, "blog.title")} — SwiftBill`}
  description={t(lang, "blog.subtitle")}
  lang={lang}
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
        {t(lang, "blog.title")}
      </h1>
      <p class="mt-4 text-lg text-text-secondary leading-relaxed">
        {t(lang, "blog.subtitle")}
      </p>
    </div>

    <!-- Category Filters -->
    <div class="mt-10 flex flex-wrap justify-center gap-2">
      {categories.map(({ key, label }) => (
        <button
          data-category={key}
          class="blog-filter-btn rounded-full px-5 py-2 text-sm font-medium transition-all border border-border bg-card text-text-secondary hover:border-brand/30 hover:text-brand data-[active]:bg-brand data-[active]:text-white data-[active]:border-brand"
          data-active={key === "all" ? "" : undefined}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Posts Grid -->
    <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" id="blog-grid">
      {posts.map((post) => (
        <article
          data-category={post.data.category}
          class="blog-post-card group flex flex-col overflow-hidden rounded-2xl border border-border-light bg-card shadow-sm transition-all duration-300 hover:border-brand/20 hover:shadow-md"
        >
          <!-- Card header with category -->
          <div class="flex items-center justify-between px-6 pt-6 pb-2">
            <span class={`inline-flex rounded-full border px-2.5 py-0.5 text-xs font-semibold ${categoryBadgeColors[post.data.category] ?? "bg-gray-50 text-gray-700 border-gray-200"}`}>
              {t(lang, `blog.categories.${post.data.category}`)}
            </span>
            <time class="text-xs text-text-tertiary" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date, lang)}
            </time>
          </div>

          <!-- Content -->
          <div class="flex flex-1 flex-col px-6 pb-6 pt-2">
            <h2 class="text-lg font-semibold text-text-primary leading-snug group-hover:text-brand transition-colors">
              <a href={getLocalizedPath(lang, `/blog/${post.id.replace(/^(en|ar)\//, "")}`)}>
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 flex-1 text-sm text-text-secondary leading-relaxed line-clamp-3">
              {post.data.description}
            </p>
            <a
              href={getLocalizedPath(lang, `/blog/${post.id.replace(/^(en|ar)\//, "")}`)}
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand transition-colors hover:text-brand-dark"
            >
              {t(lang, "blog.readMore")}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class={lang === "ar" ? "rotate-180" : ""}>
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="mt-16 text-center">
        <p class="text-text-secondary">{lang === "ar" ? "لا توجد مقالات بعد." : "No posts yet."}</p>
      </div>
    )}
  </div>
</PageLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".blog-filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".blog-post-card");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      // Update active state
      buttons.forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "");

      // Filter cards
      cards.forEach((card) => {
        if (category === "all" || card.dataset.category === category) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>
