---
import { type Lang, t, getLocalizedPath } from "@/i18n/utils";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();
const appStoreUrl = "https://apps.apple.com/app/id6760855924";

const productLinks = [
  { label: t(lang, "nav.features"), href: `${getLocalizedPath(lang)}#features` },
  { label: t(lang, "nav.pricing"), href: `${getLocalizedPath(lang)}#pricing` },
  { label: t(lang, "nav.blog"), href: getLocalizedPath(lang, "/blog") },
];

const legalLinks = [
  { label: t(lang, "footer.privacy"), href: getLocalizedPath(lang, "/privacy") },
  { label: t(lang, "footer.terms"), href: getLocalizedPath(lang, "/terms") },
];

const supportLinks = [
  { label: t(lang, "footer.contact"), href: `mailto:${t(lang, "footer.email")}` },
];
---

<footer class="bg-[#1A1A2E] text-white/90">
  <!-- Main Footer -->
  <div class="mx-auto max-w-7xl px-6 pb-12 pt-16 lg:px-8">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a
          href={getLocalizedPath(lang)}
          class="inline-flex items-center gap-2 text-white font-bold text-xl tracking-tight"
          aria-label="SwiftBill Home"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 28 28"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect width="28" height="28" rx="7" fill="#3053EC" />
            <path
              d="M16.5 4L10 15h4.5L12 24l8-11h-5l1.5-9z"
              fill="white"
              stroke="white"
              stroke-width="0.5"
              stroke-linejoin="round"
            />
          </svg>
          <span>SwiftBill</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-white/60">
          {t(lang, "footer.tagline")}
        </p>

        <!-- App Store Badge -->
        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2.5 rounded-lg border border-white/20 bg-white/5 px-4 py-2.5 text-sm font-medium text-white transition-all hover:bg-white/10"
          aria-label="Download on the App Store"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 22 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.1 22C7.79 22.05 6.8 20.68 5.96 19.47C4.25 16.56 2.93 11.3 4.7 7.72C5.57 5.94 7.36 4.86 9.28 4.84C10.56 4.82 11.78 5.73 12.57 5.73C13.36 5.73 14.85 4.62 16.4 4.8C17.07 4.83 18.94 5.07 20.12 6.8C20.01 6.87 17.79 8.15 17.82 10.87C17.85 14.14 20.65 15.22 20.68 15.23C20.65 15.31 20.2 16.86 19.12 18.44L18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z" />
          </svg>
          <div class="flex flex-col">
            <span class="text-[10px] leading-none text-white/60">Download on the</span>
            <span class="text-sm font-semibold leading-tight">App Store</span>
          </div>
        </a>

        <!-- Social Links -->
        <div class="mt-6 flex items-center gap-4">
          <a
            href="https://x.com/swiftbillapp"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/5 text-white/50 transition-all hover:bg-white/10 hover:text-white"
            aria-label="Follow us on X (Twitter)"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a
            href="https://linkedin.com/company/swiftbillapp"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/5 text-white/50 transition-all hover:bg-white/10 hover:text-white"
            aria-label="Follow us on LinkedIn"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Product Column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40">
          {t(lang, "footer.product")}
        </h3>
        <ul class="mt-4 space-y-3">
          {
            productLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/60 transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40">
          {t(lang, "footer.legal")}
        </h3>
        <ul class="mt-4 space-y-3">
          {
            legalLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/60 transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Support Column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40">
          {t(lang, "footer.support")}
        </h3>
        <ul class="mt-4 space-y-3">
          {
            supportLinks.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/60 transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={`mailto:${t(lang, "footer.email")}`}
              class="text-sm text-white/60 transition-colors hover:text-white"
            >
              {t(lang, "footer.email")}
            </a>
          </li>
        </ul>

        <div class="mt-6">
          <LanguageSwitcher lang={lang} />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div
      class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-6 sm:flex-row lg:px-8"
    >
      <p class="text-sm text-white/40">
        &copy; {currentYear} {t(lang, "footer.copyright")}
      </p>
      <p class="text-sm text-white/40">
        {t(lang, "footer.madeWith")}
      </p>
    </div>
  </div>
</footer>
