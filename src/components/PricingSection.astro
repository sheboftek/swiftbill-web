---
import { t, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const appStoreUrl = "https://apps.apple.com/app/id6760855924";

const freeFeatures = lang === "ar"
  ? ["فاتورة واحدة شهرياً", "إيصال واحد شهرياً", "قالب PDF كلاسيكي", "تقارير أساسية", "مزامنة سحابية"]
  : ["1 invoice per month", "1 receipt per month", "Classic PDF template", "Basic reports", "Cloud sync"];

const proFeatures = lang === "ar"
  ? ["فواتير وإيصالات غير محدودة", "جميع القوالب الـ 15", "إنشاء بالذكاء الاصطناعي", "تتبع المصروفات", "فواتير متكررة", "متوافق مع زاتكا وهيئة الضرائب الإماراتية", "دعم متعدد العملات", "تصدير CSV", "دعم ذو أولوية"]
  : ["Unlimited invoices & receipts", "All 15 PDF templates", "AI document generation", "Expense tracking", "Recurring invoices", "ZATCA & UAE FTA compliance", "Multi-currency support", "CSV export", "Priority support"];
---

<section id="pricing" class="py-20 sm:py-28 bg-surface/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="inline-block rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold text-brand">
        {t(lang, "pricing.label")}
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-text-primary sm:text-4xl lg:text-5xl">
        {t(lang, "pricing.title")}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-text-secondary">
        {t(lang, "pricing.subtitle")}
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="mt-12 flex items-center justify-center gap-3">
      <span id="pricing-label-monthly" class="text-sm font-semibold text-text-primary">
        {t(lang, "pricing.monthly")}
      </span>

      <button
        type="button"
        id="pricing-toggle"
        class="relative inline-flex h-7 w-14 flex-shrink-0 cursor-pointer rounded-full bg-text-tertiary/30 transition-colors duration-200 ease-in-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        role="switch"
        aria-checked="false"
        aria-label="Toggle annual pricing"
      >
        <span
          id="pricing-toggle-dot"
          class="pointer-events-none inline-block h-6 w-6 translate-x-0.5 translate-y-0.5 rounded-full bg-white shadow-sm ring-0 transition duration-200 ease-in-out"
        ></span>
      </button>

      <span id="pricing-label-yearly" class="text-sm font-medium text-text-secondary">
        {t(lang, "pricing.yearly")}
      </span>

      <span class="inline-flex items-center rounded-full bg-success/10 px-2.5 py-0.5 text-xs font-bold text-success">
        {t(lang, "pricing.yearlyDiscount")}
      </span>
    </div>

    <!-- Pricing cards -->
    <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-8 lg:grid-cols-2">
      <!-- Free plan -->
      <div class="flex flex-col rounded-2xl border border-border-light bg-card p-8 shadow-sm">
        <div class="mb-6">
          <h3 class="text-lg font-bold text-text-primary">{t(lang, "pricing.free.name")}</h3>
          <p class="mt-1 text-sm text-text-secondary">{t(lang, "pricing.free.description")}</p>
        </div>

        <div class="mb-8">
          <span class="text-5xl font-extrabold tracking-tight text-text-primary">{t(lang, "pricing.free.price")}</span>
          <span class="ms-2 text-base font-medium text-text-secondary">{t(lang, "pricing.free.period")}</span>
        </div>

        <!-- Features -->
        <ul class="mb-8 flex flex-1 flex-col gap-3.5" role="list">
          {freeFeatures.map((feature) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-success" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-text-secondary">{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full rounded-xl border-2 border-border bg-card py-3.5 text-center text-sm font-semibold text-text-primary transition-all duration-200 hover:border-brand hover:text-brand focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        >
          {t(lang, "pricing.free.cta")}
        </a>
      </div>

      <!-- Pro plan -->
      <div class="relative flex flex-col rounded-2xl border-2 border-brand bg-card p-8 shadow-lg shadow-brand/10">
        <!-- Most Popular badge -->
        <div class="absolute -top-4 inset-x-0 flex justify-center">
          <span class="inline-flex items-center gap-1 rounded-full bg-brand px-4 py-1 text-xs font-bold text-white shadow-sm">
            <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 1l1.796 4.924L15 6.5l-3.75 3.25L12.392 15 8 12.5 3.608 15l1.142-5.25L1 6.5l5.204-.576L8 1z"/>
            </svg>
            {lang === "ar" ? "الأكثر شعبية" : "Most Popular"}
          </span>
        </div>

        <div class="mb-6">
          <h3 class="text-lg font-bold text-text-primary">{t(lang, "pricing.pro.name")}</h3>
          <p class="mt-1 text-sm text-text-secondary">{t(lang, "pricing.pro.description")}</p>
        </div>

        <div class="mb-2">
          <span id="pricing-pro-price" class="text-5xl font-extrabold tracking-tight text-text-primary">
            {t(lang, "pricing.pro.priceMonthly")}
          </span>
          <span id="pricing-pro-period" class="ms-2 text-base font-medium text-text-secondary">
            {t(lang, "pricing.pro.periodMonthly")}
          </span>
        </div>

        <p id="pricing-pro-trial" class="mb-8 text-sm font-medium text-brand">
          {t(lang, "pricing.pro.trialMonthly")}
        </p>

        <!-- Features -->
        <ul class="mb-8 flex flex-1 flex-col gap-3.5" role="list">
          {proFeatures.map((feature) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-success" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-sm text-text-secondary">{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full rounded-xl bg-brand py-3.5 text-center text-sm font-semibold text-white shadow-sm shadow-brand/25 transition-all duration-200 hover:bg-brand-dark hover:shadow-md hover:shadow-brand/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        >
          {t(lang, "pricing.pro.cta")}
        </a>
      </div>
    </div>
  </div>
</section>

<script
  define:vars={{
    priceMonthly: t(lang, "pricing.pro.priceMonthly"),
    priceYearly: t(lang, "pricing.pro.priceYearly"),
    periodMonthly: t(lang, "pricing.pro.periodMonthly"),
    periodYearly: t(lang, "pricing.pro.periodYearly"),
    trialMonthly: t(lang, "pricing.pro.trialMonthly"),
    trialYearly: t(lang, "pricing.pro.trialYearly"),
  }}
>
  const toggle = document.getElementById("pricing-toggle");
  const dot = document.getElementById("pricing-toggle-dot");
  const labelMonthly = document.getElementById("pricing-label-monthly");
  const labelYearly = document.getElementById("pricing-label-yearly");
  const proPrice = document.getElementById("pricing-pro-price");
  const proPeriod = document.getElementById("pricing-pro-period");
  const proTrial = document.getElementById("pricing-pro-trial");

  let isYearly = false;

  function updatePricing() {
    if (isYearly) {
      toggle.setAttribute("aria-checked", "true");
      toggle.classList.remove("bg-text-tertiary/30");
      toggle.classList.add("bg-brand");
      dot.classList.remove("translate-x-0.5");
      dot.classList.add("translate-x-[1.875rem]");
      labelMonthly.classList.remove("font-semibold", "text-text-primary");
      labelMonthly.classList.add("font-medium", "text-text-secondary");
      labelYearly.classList.remove("font-medium", "text-text-secondary");
      labelYearly.classList.add("font-semibold", "text-text-primary");
      proPrice.textContent = priceYearly;
      proPeriod.textContent = periodYearly;
      proTrial.textContent = trialYearly;
    } else {
      toggle.setAttribute("aria-checked", "false");
      toggle.classList.add("bg-text-tertiary/30");
      toggle.classList.remove("bg-brand");
      dot.classList.add("translate-x-0.5");
      dot.classList.remove("translate-x-[1.875rem]");
      labelMonthly.classList.add("font-semibold", "text-text-primary");
      labelMonthly.classList.remove("font-medium", "text-text-secondary");
      labelYearly.classList.add("font-medium", "text-text-secondary");
      labelYearly.classList.remove("font-semibold", "text-text-primary");
      proPrice.textContent = priceMonthly;
      proPeriod.textContent = periodMonthly;
      proTrial.textContent = trialMonthly;
    }
  }

  toggle.addEventListener("click", () => {
    isYearly = !isYearly;
    updatePricing();
  });
</script>
