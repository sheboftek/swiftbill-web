---
import { t, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const appStoreUrl = "https://apps.apple.com/app/id6760855924";

const zatcaFeatures = lang === "ar"
  ? ["رمز QR مع ترميز TLV", "تنسيقات عربية وثنائية اللغة", "حساب ضريبة القيمة المضافة", "أرقام التسجيل الضريبي"]
  : ["QR Code with TLV Encoding", "Arabic & Bilingual Formats", "VAT Calculation", "Tax Registration Numbers"];

const uaeFeatures = lang === "ar"
  ? ["تنسيق متوافق مع الهيئة", "عرض رقم التسجيل الضريبي", "نسخ إنجليزية وعربية", "تفصيل ضريبة القيمة المضافة"]
  : ["FTA Compliant Format", "TRN Display", "English & Arabic Variants", "VAT Breakdown"];
---

<section id="compliance" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <span class="inline-block rounded-full bg-brand-50 px-4 py-1.5 text-sm font-semibold text-brand">
        {t(lang, "compliance.label")}
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-text-primary sm:text-4xl lg:text-5xl">
        {t(lang, "compliance.title")}
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-text-secondary">
        {t(lang, "compliance.subtitle")}
      </p>
    </div>

    <!-- Compliance cards -->
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 lg:grid-cols-2">
      <!-- ZATCA card (Saudi Arabia) -->
      <div class="relative overflow-hidden rounded-2xl border border-border-light bg-card shadow-sm">
        <!-- Green accent border top -->
        <div class="h-1.5 w-full bg-gradient-to-r from-emerald-400 to-emerald-600" aria-hidden="true"></div>

        <!-- Subtle green background -->
        <div class="absolute inset-0 top-1.5 bg-gradient-to-b from-emerald-50/40 to-transparent" aria-hidden="true"></div>

        <div class="relative p-8 sm:p-10">
          <!-- Country badge -->
          <div class="mb-6 flex items-center gap-3">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <rect x="7" y="7" width="10" height="10" rx="1" ry="1"/>
                <line x1="7" y1="2" x2="7" y2="5"/>
                <line x1="17" y1="2" x2="17" y2="5"/>
                <line x1="7" y1="19" x2="7" y2="22"/>
                <line x1="17" y1="19" x2="17" y2="22"/>
                <line x1="2" y1="7" x2="5" y2="7"/>
                <line x1="2" y1="17" x2="5" y2="17"/>
                <line x1="19" y1="7" x2="22" y2="7"/>
                <line x1="19" y1="17" x2="22" y2="17"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-primary">{t(lang, "compliance.zatca.title")}</h3>
              <p class="text-xs font-semibold uppercase tracking-wider text-emerald-600">
                {t(lang, "compliance.zatca.subtitle")}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-sm leading-relaxed text-text-secondary mb-6">
            {t(lang, "compliance.zatca.description")}
          </p>

          <!-- Feature list -->
          <ul class="flex flex-col gap-2.5" role="list">
            {zatcaFeatures.map((feature) => (
              <li class="flex items-center gap-3">
                <div class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100">
                  <svg class="h-3 w-3 text-emerald-600" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2.5 6l2.5 2.5 4.5-5"/>
                  </svg>
                </div>
                <span class="text-sm font-medium text-text-primary">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- UAE FTA card (United Arab Emirates) -->
      <div class="relative overflow-hidden rounded-2xl border border-border-light bg-card shadow-sm">
        <!-- Red accent border top -->
        <div class="h-1.5 w-full bg-gradient-to-r from-red-400 to-red-600" aria-hidden="true"></div>

        <!-- Subtle red background -->
        <div class="absolute inset-0 top-1.5 bg-gradient-to-b from-red-50/40 to-transparent" aria-hidden="true"></div>

        <div class="relative p-8 sm:p-10">
          <!-- Country badge -->
          <div class="mb-6 flex items-center gap-3">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-red-50 text-red-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-text-primary">{t(lang, "compliance.uae.title")}</h3>
              <p class="text-xs font-semibold uppercase tracking-wider text-red-600">
                {t(lang, "compliance.uae.subtitle")}
              </p>
            </div>
          </div>

          <!-- Description -->
          <p class="text-sm leading-relaxed text-text-secondary mb-6">
            {t(lang, "compliance.uae.description")}
          </p>

          <!-- Feature list -->
          <ul class="flex flex-col gap-2.5" role="list">
            {uaeFeatures.map((feature) => (
              <li class="flex items-center gap-3">
                <div class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-red-100">
                  <svg class="h-3 w-3 text-red-600" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2.5 6l2.5 2.5 4.5-5"/>
                  </svg>
                </div>
                <span class="text-sm font-medium text-text-primary">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-14 text-center">
      <a
        href={appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 rounded-xl bg-brand px-8 py-4 text-base font-semibold text-white shadow-lg shadow-brand/25 transition-all duration-200 hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
      >
        <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M14.94 5.19A4.38 4.38 0 0 0 12 3.94a4.44 4.44 0 0 0-2.94 1.25 4.18 4.18 0 0 0-1.23 2.87c1.53.12 2.85-.83 3.6-2.06.74-1.2.98-2.56.51-3.81zm.66 3.81c-1.6.08-2.95.91-3.7.91-.77 0-1.95-.86-3.22-.84a4.77 4.77 0 0 0-4.04 2.45c-1.73 3-.44 7.46 1.23 9.9.83 1.2 1.81 2.53 3.1 2.48 1.24-.05 1.72-.8 3.22-.8 1.5 0 1.93.8 3.24.78 1.34-.02 2.18-1.22 3-2.42a10.7 10.7 0 0 0 1.36-2.78 4.27 4.27 0 0 1-2.57-3.9 4.34 4.34 0 0 1 2.07-3.63 4.46 4.46 0 0 0-3.49-2.1z"/>
        </svg>
        {t(lang, "compliance.cta")}
      </a>
    </div>
  </div>
</section>
