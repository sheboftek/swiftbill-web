---
import { t, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const appStoreUrl = "https://apps.apple.com/app/id6760855924";
---

<section class="relative overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24">
  <!-- Background gradient mesh -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute top-0 start-1/2 -translate-x-1/2 w-[1200px] h-[800px] rounded-full bg-[radial-gradient(ellipse_at_center,_rgba(48,83,236,0.08)_0%,_rgba(74,108,247,0.04)_35%,_transparent_70%)]"></div>
    <div class="absolute bottom-0 end-0 w-[600px] h-[600px] rounded-full bg-[radial-gradient(ellipse_at_center,_rgba(48,83,236,0.05)_0%,_transparent_60%)]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-100 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand mb-6">
        <svg class="h-4 w-4 text-brand-light flex-shrink-0" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 1l1.796 4.924L15 6.5l-3.75 3.25L12.392 15 8 12.5 3.608 15l1.142-5.25L1 6.5l5.204-.576L8 1z" fill="currentColor"/>
        </svg>
        {t(lang, "hero.badge")}
      </div>

      <!-- Headline — LCP: no animation, no opacity:0, no transform -->
      <h1 class="mx-auto max-w-4xl text-4xl font-extrabold tracking-tight text-text-primary sm:text-5xl md:text-6xl lg:text-7xl">
        {t(lang, "hero.title")}{" "}
        <span class="bg-gradient-to-r from-brand to-brand-light bg-clip-text text-transparent">
          {t(lang, "hero.titleHighlight")}
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-secondary sm:text-xl">
        {t(lang, "hero.subtitle")}
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <!-- Primary: App Store -->
        <a
          href={appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 rounded-xl bg-brand px-7 py-4 text-base font-semibold text-white shadow-lg shadow-brand/25 transition-all duration-200 hover:bg-brand-dark hover:shadow-xl hover:shadow-brand/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        >
          <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M14.94 5.19A4.38 4.38 0 0 0 12 3.94a4.44 4.44 0 0 0-2.94 1.25 4.18 4.18 0 0 0-1.23 2.87c1.53.12 2.85-.83 3.6-2.06.74-1.2.98-2.56.51-3.81zm.66 3.81c-1.6.08-2.95.91-3.7.91-.77 0-1.95-.86-3.22-.84a4.77 4.77 0 0 0-4.04 2.45c-1.73 3-.44 7.46 1.23 9.9.83 1.2 1.81 2.53 3.1 2.48 1.24-.05 1.72-.8 3.22-.8 1.5 0 1.93.8 3.24.78 1.34-.02 2.18-1.22 3-2.42a10.7 10.7 0 0 0 1.36-2.78 4.27 4.27 0 0 1-2.57-3.9 4.34 4.34 0 0 1 2.07-3.63 4.46 4.46 0 0 0-3.49-2.1z"/>
          </svg>
          {t(lang, "hero.cta")}
        </a>

        <!-- Secondary: See Features -->
        <a
          href="#features"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-border bg-card px-7 py-4 text-base font-semibold text-text-primary transition-all duration-200 hover:border-brand hover:text-brand focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        >
          {t(lang, "hero.ctaSecondary")}
          <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 6l4 4 4-4"/>
          </svg>
        </a>
      </div>

      <!-- Stats bar -->
      <div class="mx-auto mt-14 max-w-xl">
        <div class="flex items-center justify-center gap-3 rounded-2xl border border-border-light bg-card/80 px-6 py-4 shadow-sm backdrop-blur-sm sm:gap-6 sm:px-8">
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-brand flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-semibold text-text-primary whitespace-nowrap">{t(lang, "hero.stats.templates")}</span>
          </div>

          <div class="h-5 w-px bg-border" aria-hidden="true"></div>

          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-brand flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M7 2a1 1 0 011 1v1h3a1 1 0 110 2H9.578a18.87 18.87 0 01-1.724 4.78c.29.354.596.69.914 1.005a1 1 0 11-1.42 1.42 16.853 16.853 0 01-.58-.58c-.642.768-1.347 1.454-2.102 2.04a1 1 0 11-1.228-1.578A16.1 16.1 0 005.3 9.865 18.812 18.812 0 004.064 7H3a1 1 0 010-2h3V3a1 1 0 011-1zm6 6a1 1 0 011 1v.01a1 1 0 11-2 0V9a1 1 0 011-1zm-1 4a1 1 0 011-1h.01a1 1 0 110 2H13a1 1 0 01-1-1z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-semibold text-text-primary whitespace-nowrap">{t(lang, "hero.stats.languages")}</span>
          </div>

          <div class="h-5 w-px bg-border" aria-hidden="true"></div>

          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-brand flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
            </svg>
            <span class="text-sm font-semibold text-text-primary whitespace-nowrap">{t(lang, "hero.stats.currencies")}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
